# Database
DATABASE_URL="postgresql://user:password@localhost:5432/leve_chopp"

# JWT
JWT_SECRET="sua-chave-secreta-super-longa-aqui"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# Twilio WhatsApp
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-token"
TWILIO_WHATSAPP_NUMBER="+55119999999999"

# Google Maps
GOOGLE_MAPS_API_KEY="your-google-maps-key"

# SendGrid Email
SENDGRID_API_KEY="your-sendgrid-key"
SENDGRID_FROM_EMAIL="noreply@levechopp.com.br"

# Stripe / Pagamento
STRIPE_PUBLIC_KEY="your-stripe-public"
STRIPE_SECRET_KEY="your-stripe-secret"

# Sentry
SENTRY_DSN="your-sentry-dsn"

# Environment
NODE_ENV="development"
API_PORT="3001"
API_HOST="0.0.0.0"
API_BASE_URL="http://localhost:3001"
WEB_BASE_URL="http://localhost:3000"

# Logging
LOG_LEVEL="debug"
